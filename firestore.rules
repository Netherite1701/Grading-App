rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Assumed data model:
    // - users/{uid}: uid, email, displayName?, photoURL?, role, createdAt, updatedAt?
    // - events/{eventId}: event setup, owner metadata, criteria, status, timestamps
    // - participants/{participantId}: team/project metadata plus eventId
    // - scorecards/{scorecardId}: judgeId, authUid?, participantId, eventId, scores, totalScore
    // - appConfig/translations: published UI translation overrides

    function signedIn() {
      return request.auth != null;
    }

    function hasVerifiedEmail() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function hasAllowedEmailDomain() {
      return hasVerifiedEmail()
        && request.auth.token.email is string
        && request.auth.token.email.matches("^[^@]+@soongsil\\.net$");
    }

    function isTeacherQrAuth() {
      return signedIn()
        && request.auth.token.firebase is map
        && request.auth.token.firebase.sign_in_provider == "anonymous";
    }

    function canAccessApp() {
      return signedIn() && (hasAllowedEmailDomain() || isTeacherQrAuth());
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserExists() {
      return canAccessApp() && exists(currentUserPath());
    }

    function currentRole() {
      return currentUserExists() ? get(currentUserPath()).data.role : "guest";
    }

    function isDeveloper() {
      return currentRole() == "developer"
        || currentRole() == "Developer"
        || currentRole() == "DEVELOPER"
        || currentRole() == "dev"
        || currentRole() == "Dev"
        || currentRole() == "DEV";
    }

    function isOrganizer() {
      return currentRole() == "organizer"
        || currentRole() == "Organizer"
        || currentRole() == "ORGANIZER"
        || currentRole() == "admin"
        || currentRole() == "Admin"
        || currentRole() == "ADMIN"
        || isDeveloper();
    }

    function isJudge() {
      return currentRole() == "judge"
        || currentRole() == "Judge"
        || currentRole() == "JUDGE"
        || isDeveloper();
    }

    function isGuestRole(role) {
      return role == "guest"
        || role == "Guest"
        || role == "GUEST";
    }

    function isTeacherQrUserWrite(uid) {
      return isTeacherQrAuth()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == ""
        && request.resource.data.role == "judge";
    }

    match /users/{uid} {
      allow read: if canAccessApp();
      allow create: if canAccessApp()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (
          (
            request.resource.data.email == request.auth.token.email
            && isGuestRole(request.resource.data.role)
          )
          || isTeacherQrUserWrite(uid)
        );
      allow update: if canAccessApp()
        && (
          isDeveloper()
          || (
            request.auth.uid == uid
            && request.resource.data.role == resource.data.role
          )
          || isTeacherQrUserWrite(uid)
        );
      allow delete: if isDeveloper();
    }

    match /events/{eventId} {
      allow read: if canAccessApp();
      allow create, update, delete: if isOrganizer();
    }

    match /participants/{participantId} {
      allow read: if canAccessApp();
      allow create, update, delete: if isOrganizer();
    }

    match /scorecards/{scorecardId} {
      allow read: if canAccessApp();
      allow create, update: if isJudge()
        && (
          request.resource.data.judgeId == request.auth.uid
          || request.resource.data.authUid == request.auth.uid
        );
      allow delete: if isDeveloper();
    }

    match /appConfig/{configId} {
      allow read: if canAccessApp();
      allow create, update, delete: if configId == "translations" && isDeveloper();
    }
  }
}
