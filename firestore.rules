rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserExists() {
      return signedIn() && exists(currentUserPath());
    }

    function currentRole() {
      return currentUserExists() ? lower(get(currentUserPath()).data.role) : "guest";
    }

    function isDeveloper() {
      return currentRole() == "developer" || currentRole() == "dev";
    }

    function isOrganizer() {
      return currentRole() == "organizer" || currentRole() == "admin" || isDeveloper();
    }

    function isJudge() {
      return currentRole() == "judge" || isDeveloper();
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == "guest";
      allow update: if signedIn()
        && (
          isDeveloper()
          || (
            request.auth.uid == uid
            && request.resource.data.role == resource.data.role
          )
        );
      allow delete: if isDeveloper();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create, update, delete: if isOrganizer();
    }

    match /participants/{participantId} {
      allow read: if signedIn();
      allow create, update, delete: if isOrganizer();
    }

    match /scorecards/{scorecardId} {
      allow read: if signedIn();
      allow create, update: if isJudge()
        && request.resource.data.judgeId == request.auth.uid;
      allow delete: if isDeveloper();
    }
  }
}
